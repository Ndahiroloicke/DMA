{
  "expo": {
    "name": "LexiSearch",
    "slug": "DictionaryMobileApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lexitech.lexisearch",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app requires microphone access for pronunciation audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A73E8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.lexitech.lexisearch",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-asset"
    ]
  }
}
